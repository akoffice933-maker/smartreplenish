   "source": [
    "# 📦 SmartReplenish: EDA + Baseline Model\n",
    "\n",
    "## Разведочный анализ данных и построение базовой модели прогнозирования\n",
    "\n",
    "**Цель:** Проанализировать данные о продажах, выявить паттерны и построить baseline модель с оценкой точности (WAPE, MAPE, Bias).\n",
    "\n",
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Импорт библиотек\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from sklearn.metrics import mean_absolute_error, mean_squared_error\n",
    "from sklearn.ensemble import RandomForestRegressor\n",
    "import lightgbm as lgb\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Настройка визуализации\n",
    "plt.style.use('seaborn-v0_8-darkgrid')\n",
    "sns.set_palette('husl')\n",
    "plt.rcParams['figure.figsize'] = (12, 6)\n",
    "plt.rcParams['font.size'] = 10"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1️⃣ Загрузка данных"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Загрузка данных\n",
    "df = pd.read_csv('../sample_data/sales_sample.csv')\n",
    "df['date'] = pd.to_datetime(df['date'])\n",
    "\n",
    "print(f\"📊 Размер данных: {df.shape[0]} строк, {df.shape[1]} колонок\")\n",
    "print(f\"\\n📅 Период: {df['date'].min()} — {df['date'].max()}\")\n",
    "print(f\"\\n🏪 Магазины: {df['shop_id'].nunique()}\")\n",
    "print(f\"📦 Товары: {df['sku_id'].nunique()}\")\n",
    "print(f\"\\n📋 Первые 5 строк:\")\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2️⃣ Разведочный анализ (EDA)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Статистика по категориям\n",
    "category_stats = df.groupby('category').agg({\n",
    "    'quantity': ['sum', 'mean', 'std'],\n",
    "    'price': 'mean'\n",
    "}).round(2)\n",
    "category_stats.columns = ['Total Qty', 'Avg Qty', 'Std Qty', 'Avg Price']\n",
    "category_stats['Revenue'] = (category_stats['Total Qty'] * category_stats['Avg Price']).map('${:,.0f}'.format)\n",
    "category_stats"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Визуализация распределения продаж\n",
    "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
    "\n",
    "# 1. Распределение количества продаж\n",
    "axes[0, 0].hist(df['quantity'], bins=30, edgecolor='black', alpha=0.7)\n",
    "axes[0, 0].set_title('Распределение количества продаж')\n",
    "axes[0, 0].set_xlabel('Количество')\n",
    "axes[0, 0].set_ylabel('Частота')\n",
    "\n",
    "# 2. Продажи по категориям\n",
    "cat_sales = df.groupby('category')['quantity'].sum().sort_values(ascending=False)\n",
    "axes[0, 1].bar(cat_sales.index, cat_sales.values, color=sns.color_palette('husl', len(cat_sales)))\n",
    "axes[0, 1].set_title('Продажи по категориям')\n",
    "axes[0, 1].set_xlabel('Категория')\n",
    "axes[0, 1].set_ylabel('Общее количество')\n",
    "plt.setp(axes[0, 1].xaxis.get_majorticklabels(), rotation=45, ha='right')\n",
    "\n",
    "# 3. Продажи по дням недели\n",
    "dow_sales = df.groupby('day_of_week')['quantity'].mean()\n",
    "axes[1, 0].plot(dow_sales.index, dow_sales.values, marker='o', linewidth=2, markersize=8)\n",
    "axes[1, 0].set_title('Средние продажи по дням недели')\n",
    "axes[1, 0].set_xlabel('День недели (0=Пн, 6=Вс)')\n",
    "axes[1, 0].set_ylabel('Среднее количество')\n",
    "axes[1, 0].set_xticks(range(7))\n",
    "axes[1, 0].set_xticklabels(['Пн', 'Вт', 'Ср', 'Чт', 'Пт', 'Сб', 'Вс'])\n",
    "\n",
    "# 4. Влияние промо\n",
    "promo_sales = df.groupby('promo_flag')['quantity'].mean()\n",
    "axes[1, 1].bar(['Без промо', 'С промо'], promo_sales.values, color=['#3498db', '#e74c3c'])\n",
    "axes[1, 1].set_title('Влияние промо на продажи')\n",
    "axes[1, 1].set_ylabel('Среднее количество')\n",
    "promo_lift = ((promo_sales[1] - promo_sales[0]) / promo_sales[0] * 100)\n",
    "axes[1, 1].text(0.5, promo_sales.max() * 0.9, f'Promo Lift: +{promo_lift:.1f}%', \n",
    "               ha='center', fontsize=12, fontweight='bold', bbox=dict(boxstyle='round', facecolor='wheat'))\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Временной ряд продаж (агрегация по дням)\n",
    "daily_sales = df.groupby('date')['quantity'].sum().reset_index()\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(14, 5))\n",
    "ax.plot(daily_sales['date'], daily_sales['quantity'], linewidth=2, marker='o', markersize=3)\n",
    "ax.set_title('Динамика продаж во времени', fontsize=14, fontweight='bold')\n",
    "ax.set_xlabel('Дата')\n",
    "ax.set_ylabel('Общее количество')\n",
    "ax.grid(True, alpha=0.3)\n",
    "\n",
    # Выделение выходных\n",
    "weekends = daily_sales[daily_sales['date'].dt.dayofweek >= 5]\n",
    "ax.scatter(weekends['date'], weekends['quantity'], color='red', alpha=0.5, s=50, label='Выходные')\n",
    "ax.legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3️⃣ Feature Engineering"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Создание признаков для модели\n",
    "def create_features(df):\n",
    "    df = df.copy()\n",
    "    \n",
    "    # Временные признаки\n",
    "    df['month'] = df['date'].dt.month\n",
    "    df['day'] = df['date'].dt.day\n",
    "    df['dayofweek'] = df['date'].dt.dayofweek\n",
    "    df['is_weekend'] = (df['dayofweek'] >= 5).astype(int)\n",
    "    df['is_month_start'] = df['date'].dt.is_month_start.astype(int)\n",
    "    df['is_month_end'] = df['date'].dt.is_month_end.astype(int)\n",
    "    \n",
    "    # Лаги (для каждого SKU)\n",
    "    df = df.sort_values(['shop_id', 'sku_id', 'date'])\n",
    "    for lag in [1, 3, 7, 14]:\n",
    "        df[f'lag_{lag}'] = df.groupby(['shop_id', 'sku_id'])['quantity'].shift(lag)\n",
    "    \n",
    "    # Rolling статистики\n",
    "    for window in [3, 7, 14]:\n",
    "        df[f'rolling_mean_{window}'] = df.groupby(['shop_id', 'sku_id'])['quantity'].transform(\n",
    "            lambda x: x.shift(1).rolling(window=window, min_periods=1).mean()\n",
    "        )\n",
    "        df[f'rolling_std_{window}'] = df.groupby(['shop_id', 'sku_id'])['quantity'].transform(\n",
    "            lambda x: x.shift(1).rolling(window=window, min_periods=1).std()\n",
    "        )\n",
    "    \n",
    "    # Encoding категориальных признаков\n",
    "    df['shop_encoded'] = df['shop_id'].astype('category').cat.codes\n",
    "    df['sku_encoded'] = df['sku_id'].astype('category').cat.codes\n",
    "    df['category_encoded'] = df['category'].astype('category').cat.codes\n",
    "    \n",
    "    return df\n",
    "\n",
    "df_features = create_features(df)\n",
    "print(f\"✅ Создано признаков: {len([c for c in df_features.columns if c not in df.columns])}\")\n",
    "print(f\"\\n📋 Признаки: {[c for c in df_features.columns if c not in df.columns]}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4️⃣ Подготовка данных для обучения"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Отбор признаков для модели\n",
    "feature_cols = [\n",
    "    'lag_1', 'lag_3', 'lag_7', 'lag_14',\n",
    "    'rolling_mean_3', 'rolling_mean_7', 'rolling_mean_14',\n",
    "    'rolling_std_3', 'rolling_std_7', 'rolling_std_14',\n",
    "    'dayofweek', 'is_weekend', 'month',\n",
    "    'promo_flag', 'shop_encoded', 'sku_encoded', 'category_encoded'\n",
    "]\n",
    "\n",
    "# Удаление строк с NaN (после создания лагов)\n",
    "df_model = df_features.dropna(subset=feature_cols).copy()\n",
    "\n",
    "X = df_model[feature_cols]\n",
    "y = df_model['quantity']\n",
    "\n",
    "# Разделение на train/test (80/20)\n",
    "split_idx = int(len(X) * 0.8)\n",
    "X_train, X_test = X.iloc[:split_idx], X.iloc[split_idx:]\n",
    "y_train, y_test = y.iloc[:split_idx], y.iloc[split_idx:]\n",
    "\n",
    "print(f\"📊 Train: {len(X_train)} строк\")\n",
    "print(f\"📊 Test: {len(X_test)} строк\")\n",
    "print(f\"📊 Признаков: {len(feature_cols)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5️⃣ Обучение моделей"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Функция для расчёта метрик\n",
    "def calculate_metrics(y_true, y_pred):\n",
    "    mae = mean_absolute_error(y_true, y_pred)\n",
    "    rmse = np.sqrt(mean_squared_error(y_true, y_pred))\n",
    "    \n",
    "    # WAPE (Weighted Absolute Percentage Error)\n",
    "    wape = np.sum(np.abs(y_true - y_pred)) / np.sum(y_true) * 100\n",
    "    \n",
    "    # MAPE (Mean Absolute Percentage Error)\n",
    "    mape = np.mean(np.abs((y_true - y_pred) / y_true)) * 100\n",
    "    \n",
    "    # Bias (среднее отклонение)\n",
    "    bias = (np.sum(y_pred - y_true) / np.sum(y_true)) * 100\n",
    "    \n",
    "    return {\n",
    "        'MAE': round(mae, 2),\n",
    "        'RMSE': round(rmse, 2),\n",
    "        'WAPE': round(wape, 2),\n",
    "        'MAPE': round(mape, 2),\n",
    "        'Bias': round(bias, 2)\n",
    "    }\n",
    "\n",
    "# 1. Random Forest (baseline)\n",
    "print(\"🌲 Обучение Random Forest...\")\n",
    "rf_model = RandomForestRegressor(n_estimators=100, random_state=42, n_jobs=-1)\n",
    "rf_model.fit(X_train, y_train)\n",
    "rf_pred = rf_model.predict(X_test)\n",
    "rf_metrics = calculate_metrics(y_test, rf_pred)\n",
    "print(f\"✅ Random Forest метрики: {rf_metrics}\")\n",
    "\n",
    "# 2. LightGBM (production model)\n",
    "print(\"\\n💡 Обучение LightGBM...\")\n",
    "lgb_model = lgb.LGBMRegressor(\n",
    "    n_estimators=200,\n",
    "    learning_rate=0.05,\n",
    "    max_depth=6,\n",
    "    num_leaves=31,\n",
    "    random_state=42,\n",
    "    n_jobs=-1,\n",
    "    verbose=-1\n",
    ")\n",
    "lgb_model.fit(X_train, y_train)\n",
    "lgb_pred = lgb_model.predict(X_test)\n",
    "lgb_metrics = calculate_metrics(y_test, lgb_pred)\n",
    "print(f\"✅ LightGBM метрики: {lgb_metrics}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Сравнение моделей\n",
    "comparison = pd.DataFrame({\n",
    "    'Random Forest': rf_metrics,\n",
    "    'LightGBM': lgb_metrics\n",
    "}).T\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# 1. Таблица метрик\n",
    "axes[0].axis('tight')\n",
    "axes[0].axis('off')\n",
    "table = axes[0].table(\n",
    "    cellText=comparison.values,\n",
    "    colLabels=comparison.columns,\n",
    "    rowLabels=comparison.index,\n",
    "    cellLoc='center',\n",
    "    loc='center',\n",
    "    bbox=[0, 0, 1, 1]\n",
    ")\n",
    "table.auto_set_font_size(False)\n",
    "table.set_fontsize(12)\n",
    "table.scale(1.2, 1.5)\n",
    "axes[0].set_title('Сравнение метрик моделей', fontsize=14, fontweight='bold', pad=20)\n",
    "\n",
    "# 2. Бар-чарт WAPE\n",
    "models = comparison.index\n",
    "wape_values = comparison['WAPE']\n",
    "colors = ['#e74c3c' if v > 22 else '#2ecc71' for v in wape_values]\n",
    "axes[1].bar(models, wape_values, color=colors, edgecolor='black', linewidth=2)\n",
    "axes[1].axhline(y=22, color='orange', linestyle='--', linewidth=2, label='Цель: WAPE < 22%')\n",
    "axes[1].set_title('WAPE по моделям', fontsize=14, fontweight='bold')\n",
    "axes[1].set_ylabel('WAPE, %')\n",
    "axes[1].set_ylim(0, max(wape_values) * 1.2)\n",
    "axes[1].legend()\n",
    "for i, v in enumerate(wape_values):\n",
    "    axes[1].text(i, v + 0.5, f'{v}%', ha='center', fontsize=12, fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
